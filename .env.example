# Copy to .env (gitignored) and fill in. Set the same VITE_* vars in Vercel.

# reilly-home Supabase project
VITE_SUPABASE_URL=
# anon PUBLIC key only — NEVER the service_role secret key (build-spec §6)
VITE_SUPABASE_ANON_KEY=

# alpha | beta  — governs the four seams (config.js)
VITE_MODE=alpha

# Synthetic email domain for username login (you own reilly.live). Optional.
VITE_AUTH_EMAIL_DOMAIN=grove.reilly.live

# ── Server-side only (DO NOT prefix with VITE_, never commit) ───────────
# Used by `npm run seed` to pre-create the Ren + Mav accounts. Run locally/CI,
# not in the browser bundle.
#   SUPABASE_URL=
#   SUPABASE_SERVICE_KEY=      # service_role key
#   REN_PASSWORD=
#   MAV_PASSWORD=
